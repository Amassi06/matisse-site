---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import CtaCommander from '../components/CtaCommander.astro';
import ReseauxWidget from '../components/ReseauxWidget.astro';
import infos from '../data/infos.json';
import { menu } from '../lib/menu';
import photoBerliner from '../assets/photos/Matisse P10.png';
import photoBurger from '../assets/photos/Matisse P5.jpeg';
import photoBroche from '../assets/photos/broche-kebab.webp';
import photoViandes from '../assets/photos/Matisse P13.png';

const titre = 'Matisse — Berliner Kebab, bowls & smash burgers à Paris 14e & Ivry-sur-Seine';
const description =
  'Matisse, street food maison depuis 1998 : kebabs berliner, bowls frais, smash burgers et frites maison. Deux restaurants — Paris 14e (Alésia) et Ivry-sur-Seine. Sur place, à emporter ou en livraison.';

// Sélection des coups de cœur et best-sellers pour la vitrine
const favoris = menu.sections
  .flatMap((section) =>
    section.groupes.flatMap((groupe) =>
      groupe.items
        .filter((item) => item.badges.includes('bestseller') || item.badges.includes('coeur'))
        .map((item) => ({ ...item, sectionId: section.id, sectionTitre: section.titre }))
    )
  )
  .slice(0, 6);

const univers = [
  {
    id: 'sandwichs',
    titre: 'Sandwichs & wraps',
    photo: photoBerliner,
    alt: 'Kebab Berliner Matisse servi avec frites maison et citronnade',
    position: '50% 50%',
    texte: 'Kebab classique, pain Berliner signature ou wrap : viande grillée à la broche et frites maison incluses.',
  },
  {
    id: 'smash-burgers',
    titre: 'Smash burgers',
    photo: photoBurger,
    alt: 'Smash burger maison avec panier de frites maison',
    position: '50% 62%',
    texte: 'Steak smashé à la plancha, cheddar fondant, bœuf, poulet crispy ou halloumi. Frites maison incluses.',
  },
] as const;

const badgesMeta = menu.badges as Record<string, { emoji: string; label: string }>;

// Vidéos maison (converties en MP4 H.264 dans public/videos/)
const videos = [
  {
    src: '/videos/matisse-1.mp4',
    poster: '/videos/matisse-1.webp',
    titre: 'De la broche au Berliner',
    label: 'La préparation du kebab Berliner en cuisine, de la broche au sandwich',
  },
  {
    src: '/videos/matisse-3.mp4',
    poster: '/videos/matisse-3.webp',
    titre: 'Smash burger, sauce maison',
    label: 'Smash burger et frites maison nappés de sauce',
  },
  {
    src: '/videos/matisse-4.mp4',
    poster: '/videos/matisse-4.webp',
    titre: 'Kebab & frites maison',
    label: 'Sandwich kebab servi avec frites maison',
  },
  {
    src: '/videos/matisse-2.mp4',
    poster: '/videos/matisse-2.webp',
    titre: 'La maison, le soir',
    label: 'La devanture du restaurant Matisse à la tombée de la nuit',
  },
] as const;
---

<Base titre={titre} description={description}>
  <!-- ============================== Héro ============================== -->
  <section class="hero">
    <div class="contenu hero__grille">
      <div class="hero__texte">
        <p class="hero__slogan">{infos.slogan}</p>
        <h1>Berliner kebabs &amp; smash burgers maison — Paris 14<sup>e</sup> &amp; Ivry</h1>
        <p class="hero__accroche">
          Viande grillée à la broche, produits frais et frites maison en deux bains de cuisson.
          Deux adresses : Alésia (Paris 14<sup>e</sup>) et Ivry-sur-Seine — sur place, à emporter
          ou en livraison.
        </p>
        <div class="hero__actions">
          <a class="btn btn--plein" href="/carte">Voir la carte</a>
          <a class="btn btn--contour" href="/nos-restaurants">
            <span aria-hidden="true">📞</span>
            Commander
          </a>
        </div>
      </div>
      <div class="hero__video">
        {
          videos.map((v, i) => (
            <video
              class:list={['hero__clip', { 'est-actif': i === 0 }]}
              src={v.src}
              poster={v.poster}
              muted
              loop
              playsinline
              preload={i === 0 ? 'auto' : 'none'}
              aria-label={v.label}
            />
          ))
        }
        <button class="hero__son" type="button" aria-pressed="false" aria-label="Activer le son">
          <span aria-hidden="true">🔇</span>
        </button>
        <div class="hero__points">
          {
            videos.map((v, i) => (
              <button
                class:list={['hero__point', { 'est-actif': i === 0 }]}
                type="button"
                data-index={i}
                aria-label={`Vidéo ${i + 1} — ${v.titre}`}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ======================= Les trois univers ======================== -->
  <section class="section" aria-labelledby="titre-univers">
    <div class="contenu">
      <p class="surtitre">La maison</p>
      <h2 id="titre-univers">Deux façons de se régaler</h2>
      <div class="univers">
        {
          univers.map((u) => (
            <a class="univers__carte reveal" href={`/carte#${u.id}`}>
              <Image
                src={u.photo}
                alt={u.alt}
                width={700}
                class="univers__visuel"
                style={`object-position: ${u.position}`}
              />
              <h3>{u.titre}</h3>
              <p>{u.texte}</p>
              <span class="univers__lien" aria-hidden="true">
                Découvrir →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========================== Best-sellers =========================== -->
  <section class="section favoris" aria-labelledby="titre-favoris">
    <div class="contenu">
      <p class="surtitre">Les stars de la carte</p>
      <h2 id="titre-favoris">Best-sellers &amp; coups de cœur</h2>
      <ul class="favoris__grille">
        {
          favoris.map((plat) => (
            <li class="favoris__carte reveal">
              <div class="favoris__entete">
                <h3>{plat.nom}</h3>
                <span class="favoris__prix">{plat.prix.toFixed(2).replace('.', ',')} €</span>
              </div>
              <p class="favoris__desc">{plat.description}</p>
              <div class="favoris__badges">
                {plat.badges.map((b) => (
                  <span class="badge">
                    <span aria-hidden="true">{badgesMeta[b].emoji}</span> {badgesMeta[b].label}
                  </span>
                ))}
              </div>
            </li>
          ))
        }
      </ul>
      <p class="favoris__suite">
        <a class="btn btn--vert" href="/carte">Toute la carte</a>
      </p>
    </div>
  </section>

  <!-- ====================== Tout est fait maison ====================== -->
  <section class="maison" aria-labelledby="titre-maison">
    <div class="contenu maison__grille">
      <div class="maison__texte">
        <p class="maison__surtitre">Notre différence</p>
        <h2 id="titre-maison">Ici, tout est fait maison</h2>
        <ul class="maison__points">
          <li>
            <strong>La viande</strong> — choisie chaque jour chez notre boucher voisin, marinée et
            préparée sur place.
          </li>
          <li>
            <strong>La broche de kebab</strong> — montée à la main dans notre cuisine, jamais
            surgelée.
          </li>
          <li>
            <strong>Les frites</strong> — pommes de terre Agria épluchées et coupées ici, cuites en
            deux bains. Incluses avec sandwichs et burgers.
          </li>
          <li><strong>Les tenders</strong> — poulet mariné et pané maison.</li>
        </ul>
      </div>
      <div class="maison__photos">
        <Image
          src={photoBroche}
          alt="La broche de kebab Matisse, montée à la main et jamais surgelée"
          width={520}
          class="maison__photo reveal"
        />
        <Image
          src={photoViandes}
          alt="Viandes marinées et boulettes préparées maison, en vitrine"
          width={520}
          class="maison__photo reveal"
        />
      </div>
    </div>
  </section>

  <!-- ========================= Suivez-nous ============================ -->
  <section class="section suivez" aria-labelledby="titre-suivez">
    <div class="contenu">
      <p class="surtitre">Sur les réseaux</p>
      <h2 id="titre-suivez">Suivez-nous</h2>
      <ReseauxWidget />
    </div>
  </section>

  <!-- ======================== Infos pratiques ========================= -->
  <section class="section" aria-labelledby="titre-infos">
    <div class="contenu infos">
      <div>
        <p class="surtitre">Infos pratiques</p>
        <h2 id="titre-infos">Passez nous voir</h2>
        {
          infos.restaurants.map((resto) => (
            <address class="infos__adresse">
              <strong>{resto.nom}</strong>
              <br />
              {resto.adresse.rue}, {resto.adresse.codePostal} {resto.adresse.ville}
            </address>
          ))
        }
        <p><a href="/nos-restaurants">Horaires, plans d'accès et livraison →</a></p>
      </div>
      <div class="infos__cta">
        <CtaCommander />
      </div>
    </div>
  </section>
</Base>

<style>
  /* --- Héro --- */
  .hero {
    background: linear-gradient(160deg, var(--vert) 0%, var(--vert-fonce) 70%, var(--vert-nuit) 100%);
    color: var(--creme);
    overflow: clip;
  }

  .hero__grille {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    align-items: center;
    gap: var(--esp-l);
    padding-block: var(--esp-xl);
  }

  .hero__slogan {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--jaune);
    margin-bottom: var(--esp-s);
  }

  .hero h1 {
    color: #fff;
    margin-bottom: var(--esp-m);
  }

  .hero__accroche {
    font-size: var(--fs-500);
    color: rgb(250 246 236 / 0.9);
    margin-bottom: var(--esp-m);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--esp-s);
  }

  .hero__actions .btn--contour {
    color: #fff;
  }

  .hero__video {
    position: relative;
    width: min(100%, 17rem);
    aspect-ratio: 9 / 16;
    margin-inline: auto;
    border-radius: var(--rayon-l);
    overflow: hidden;
    background: #000;
    box-shadow: 0 18px 45px rgb(0 0 0 / 0.45);
  }

  .hero__clip {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 600ms ease;
  }

  .hero__clip.est-actif {
    opacity: 1;
  }

  .hero__son {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 2;
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 999px;
    background: rgb(0 0 0 / 0.55);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
    transition: background var(--transition);
  }

  .hero__son:hover,
  .hero__son:focus-visible {
    background: rgb(0 0 0 / 0.8);
  }

  .hero__points {
    position: absolute;
    bottom: 0.7rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    gap: 0.45rem;
  }

  .hero__point {
    width: 0.55rem;
    height: 0.55rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.45);
    cursor: pointer;
    transition: background var(--transition), transform var(--transition);
  }

  .hero__point:hover {
    background: rgb(255 255 255 / 0.75);
  }

  .hero__point.est-actif {
    background: #fff;
    transform: scale(1.25);
  }

  @media (max-width: 52rem) {
    .hero__grille {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__video {
      width: min(100%, 12.5rem);
      order: -1;
    }
  }

  /* --- Univers --- */
  .univers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: var(--esp-m);
    margin-top: var(--esp-l);
  }

  .univers__carte {
    display: block;
    padding: var(--esp-m);
    background: var(--surface);
    border: 1px solid var(--ligne);
    border-radius: var(--rayon-l);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .univers__carte:hover {
    transform: translateY(-4px);
    box-shadow: var(--ombre);
    color: inherit;
  }

  .univers__carte h3 {
    text-transform: uppercase;
    margin-top: var(--esp-m);
  }

  .univers__carte p {
    color: var(--texte-2);
    font-size: var(--fs-300);
  }

  .univers__carte :global(.univers__visuel) {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--rayon);
  }

  .univers__lien {
    font-weight: 700;
    color: var(--orange);
  }

  /* --- Favoris --- */
  .favoris {
    background: var(--bg-2);
  }

  .favoris__grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--esp-m);
    list-style: none;
    margin: var(--esp-l) 0 0;
    padding: 0;
  }

  .favoris__carte {
    background: var(--surface);
    border: 1px solid var(--ligne);
    border-radius: var(--rayon);
    padding: var(--esp-m);
    display: flex;
    flex-direction: column;
    gap: var(--esp-xs);
  }

  .favoris__entete {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--esp-s);
  }

  .favoris__entete h3 {
    margin: 0;
    font-size: var(--fs-500);
  }

  .favoris__prix {
    font-family: var(--font-display);
    color: var(--accent-contraste);
    white-space: nowrap;
  }

  .favoris__desc {
    font-size: var(--fs-300);
    color: var(--texte-2);
    margin: 0;
    flex: 1;
  }

  .favoris__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--esp-xs);
  }

  .favoris__suite {
    margin-top: var(--esp-l);
    text-align: center;
    max-width: none;
  }

  /* --- Tout est fait maison --- */
  .maison {
    background: var(--orange);
    color: #fff;
  }

  .maison__grille {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    gap: var(--esp-l);
    align-items: center;
    padding-block: var(--esp-l);
  }

  .maison__surtitre {
    font-weight: 700;
    font-size: var(--fs-300);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ffe3b3;
    margin-bottom: var(--esp-xs);
  }

  .maison h2 {
    color: #fff;
  }

  .maison__points {
    list-style: none;
    margin: var(--esp-m) 0 0;
    padding: 0;
    display: grid;
    gap: var(--esp-s);
    color: rgb(255 255 255 / 0.92);
  }

  .maison__points strong {
    color: #fff;
  }

  .maison__photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--esp-s);
    align-items: start;
  }

  .maison__photos :global(.maison__photo) {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--rayon-l);
    box-shadow: 0 14px 34px rgb(0 0 0 / 0.25);
  }

  /* --- Infos pratiques --- */
  .infos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--esp-l);
    align-items: center;
  }

  .infos__adresse {
    font-style: normal;
    font-size: var(--fs-500);
    line-height: 1.8;
    margin-bottom: var(--esp-s);
  }
</style>

<script>
  // Carrousel vidéo du héro : les clips s'enchaînent en fondu toutes les
  // 9 s, points de navigation, bouton son, pause hors écran.
  const cadre = document.querySelector<HTMLElement>('.hero__video');
  const clips = [...document.querySelectorAll<HTMLVideoElement>('.hero__clip')];
  const points = [...document.querySelectorAll<HTMLButtonElement>('.hero__point')];
  const boutonSon = document.querySelector<HTMLButtonElement>('.hero__son');

  if (cadre && clips.length) {
    const DUREE_CLIP = 9000;
    const reduit = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let actif = 0;
    let sonActif = false;
    let visible = false;
    let minuteur: number | undefined;

    const majSon = () => {
      clips.forEach((clip, i) => {
        clip.muted = !(sonActif && i === actif);
      });
      if (boutonSon) {
        boutonSon.setAttribute('aria-pressed', String(sonActif));
        boutonSon.setAttribute('aria-label', sonActif ? 'Couper le son' : 'Activer le son');
        boutonSon.querySelector('span')!.textContent = sonActif ? '🔊' : '🔇';
      }
    };

    const afficher = (index: number) => {
      clips[actif].pause();
      clips[actif].classList.remove('est-actif');
      points[actif]?.classList.remove('est-actif');
      actif = (index + clips.length) % clips.length;
      clips[actif].classList.add('est-actif');
      points[actif]?.classList.add('est-actif');
      majSon();
      if (visible && !reduit) clips[actif].play().catch(() => {});
      // Précharge le clip suivant pour une transition sans à-coup
      const suivant = clips[(actif + 1) % clips.length];
      if (suivant.preload !== 'auto') suivant.preload = 'auto';
    };

    const planifier = () => {
      clearTimeout(minuteur);
      if (reduit || !visible) return;
      minuteur = window.setTimeout(() => {
        afficher(actif + 1);
        planifier();
      }, DUREE_CLIP);
    };

    if (!reduit) {
      const observateur = new IntersectionObserver(
        ([entree]) => {
          visible = entree.isIntersecting;
          if (visible) {
            clips[actif].play().catch(() => {});
            planifier();
          } else {
            clips[actif].pause();
            clearTimeout(minuteur);
          }
        },
        { threshold: 0.25 }
      );
      observateur.observe(cadre);
    }

    // Un clic sur la vidéo met en pause / relance (et sert de lecture
    // manuelle quand les animations sont réduites)
    clips.forEach((clip) => {
      clip.addEventListener('click', () => {
        if (clip.paused) clip.play().catch(() => {});
        else clip.pause();
      });
    });

    points.forEach((point, i) => {
      point.addEventListener('click', () => {
        afficher(i);
        if (reduit) clips[actif].play().catch(() => {});
        planifier();
      });
    });

    boutonSon?.addEventListener('click', () => {
      sonActif = !sonActif;
      majSon();
      if (sonActif) clips[actif].play().catch(() => {});
    });
  }
</script>
